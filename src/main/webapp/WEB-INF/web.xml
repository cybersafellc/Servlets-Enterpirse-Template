<?xml version="1.0" encoding="UTF-8"?>

<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee
         http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd"
         version="4.0">

    <!-- ERROR 404 -->
    <error-page>
        <error-code>404</error-code>
        <location>/errors/404.jsp</location>
    </error-page>

    <!-- ERROR 500 -->
    <error-page>
        <error-code>500</error-code>
        <location>/errors/500.jsp</location>
    </error-page>

    <!-- REGISTER FILTER -->
    <filter>
        <filter-name>DummyFilter</filter-name>
        <filter-class>org.nands.app.filters.DummyFilter</filter-class>
    </filter>

    <filter>
        <filter-name>GlobalExceptionFilter</filter-name>
        <filter-class>org.nands.app.filters.GlobalExceptionFilter</filter-class>
    </filter>

    <!-- PRIORITY -->
    <!-- LoggingFilter jalan dulu -->
    <filter-mapping>
        <filter-name>GlobalExceptionFilter</filter-name>
        <url-pattern>/*</url-pattern>
    </filter-mapping>
    <filter-mapping>
        <filter-name>DummyFilter</filter-name>
        <url-pattern>/*</url-pattern>
    </filter-mapping>


</web-app>